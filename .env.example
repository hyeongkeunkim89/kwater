# ── 물 이야기 (Supabase) ───────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI, Transaction pooler 권장)
# Vercel에서 URI에 비밀번호를 넣으면 특수문자·+ 가 깨질 수 있음 → URI는 비밀번호 없이, 아래 DATABASE_PASSWORD에 평문
DATABASE_URL=
# 서버 전용. 있으면 런타임에 DATABASE_URL에 안전 병합(평문 그대로, URL 인코딩 불필요)
DATABASE_PASSWORD=

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Project Settings → API → service_role (서버 전용, 절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY=

# 갤러리 관리(이달의 사진·삭제) — API 헤더 x-admin-secret
WATER_STORIES_ADMIN_SECRET=
