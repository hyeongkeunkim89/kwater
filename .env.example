# ── 물 이야기 (Supabase) ───────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI, Transaction pooler 권장)
# Vercel에서 URI에 비밀번호를 넣으면 특수문자·+ 가 깨질 수 있음 → URI는 비밀번호 없이, 아래 DATABASE_PASSWORD에 평문
DATABASE_URL=
# 서버 전용. 있으면 런타임에 DATABASE_URL에 안전 병합(평문 그대로, URL 인코딩 불필요)
DATABASE_PASSWORD=

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Project Settings → API → service_role (서버 전용, 절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY=

# 갤러리 관리(이달의 사진·삭제) — API 헤더 x-admin-secret
WATER_STORIES_ADMIN_SECRET=

# ── 문화관 운영 콘솔 (/yunyeong) 브라우저 접근 게이트 ───────────
# 비어 있으면 /yunyeong 은 누구나 열 수 있음. 값을 넣으면 /yunyeong/login 에서 이 비밀번호를 맞혀야 대시보드 진입.
STAFF_CONSOLE_PASSWORD=
# (선택) 콘솔 세션 쿠키 서명용. 없으면 WATER_STORIES_ADMIN_SECRET → STAFF_CONSOLE_PASSWORD 순으로 사용.
STAFF_CONSOLE_SESSION_SECRET=

# ── 가이드 투어 예약 (물 이야기와 별도 DB·연결) ─────────────────
#
# [Vercel 배포 시 할 일 — 순서 권장]
# 1) Supabase(또는 Postgres)에서 예약용 DB를 정한다.
#    - 물 이야기와 같은 프로젝트를 써도 되고, 다른 프로젝트를 써도 됨.
#    - 앱은 `DATABASE_URL`(물 이야기)과 `RESERVATIONS_DATABASE_URL`(예약)을 서로 다른 풀로 연결한다.
# 2) Supabase Dashboard → SQL Editor → New query → 저장소의 `db/tour-reservations.sql` 전체를 붙여넣고 Run.
#    - Transaction pooler(포트 6543)를 쓰는 경우, 앱이 자동 CREATE TABLE 하지 못할 수 있으므로 이 단계가 사실상 필수.
#    - 성공 후 Table Editor에 `tour_reservations`가 보이는지 확인.
# 3) Vercel → 해당 프로젝트 → Settings → Environment Variables
#    - Production(및 Preview가 예약을 쓰면 Preview도)에 아래 키 추가:
#      RESERVATIONS_DATABASE_URL = Database → Connection string → URI (Transaction pooler 권장)
#      RESERVATIONS_DATABASE_PASSWORD = (선택) URI에 비밀번호를 넣지 않을 때. 평문, URL 인코딩 불필요.
#      · `RESERVATIONS_DATABASE_PASSWORD`가 비어 있고, `RESERVATIONS_DATABASE_URL`이 물 이야기와 같은 Supabase 프로젝트면
#        앱이 `DATABASE_PASSWORD`를 자동으로 붙입니다(28P01 방지). 다른 프로젝트만 쓰면 예약 전용 변수에 꼭 넣으세요.
#      WATER_STORIES_ADMIN_SECRET = 예약 목록·상태 변경·삭제 API에 쓰는 x-admin-secret과 동일 값.
#    - 물 이야기용 DATABASE_URL / DATABASE_PASSWORD / Supabase 키는 기존과 동일하게 유지.
# 4) Save 후 Deployments에서 Redeploy(또는 main에 push해 새 빌드).
# 5) 검증: /reserve 에서 날짜 선택 후 슬롯 잔여가 뜨는지, 예약 제출 후 /yunyeong(운영 콘솔)에서 비밀번호 입력·목록 새로고침으로 보이는지. (구 /admin 은 /yunyeong 으로 리다이렉트)
#
# 예약 API·저장소는 `RESERVATIONS_DATABASE_URL`만 본다. 물 이야기와 같은 DB 인스턴스를 쓰려면 `DATABASE_URL`과 동일한 URI를 복사해 넣으면 된다.
RESERVATIONS_DATABASE_URL=
# 서버 전용. 비어 있으면(같은 Supabase일 때) DATABASE_PASSWORD로 대체 병합
RESERVATIONS_DATABASE_PASSWORD=
